{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-progress-bar",
    "core:window:allow-set-badge-label",
    "dialog:default",
    "shell:allow-open"
  ]
}
